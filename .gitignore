# Datos crudos descargados (se regeneran con ingest.py)
data/raw/*.csv
# Cache de respuestas de API-Football (se regenera con la key; crece por cosecha)
data/raw/api_cache/
# NOTA: data/processed/ (jugadores.csv, partidos.csv, calibracion.json) SI se commitea
# a proposito, para que un colaborador corra el motor sin re-scrapear FBref (~2MB).
# Pero el log de predicciones NO (cada uno acumula el suyo; evita conflictos de merge).
# Cubre el canonico (server), el sandbox -dev (local) y los consolidados.
data/processed/predicciones_*.csv

# Python
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/

# Notebooks
.ipynb_checkpoints/

# Modelos entrenados
models/*.pkl

# Artefactos de scraping (seleniumbase / chromedriver)
downloaded_files/
*.lock

# Config local de Claude Code (personal, no compartir)
.claude/settings.local.json

# Secretos / API keys -- NUNCA commitear (la key de API-Football va por variable de entorno)
.env
*.key
secrets.*

# Entornos / IDE
.vscode/
.idea/

# Sistema
.DS_Store
Thumbs.db
