# Copia este archivo como .env (en la raiz del proyecto) y completa tus credenciales.
# El .env esta en .gitignore -> NUNCA se sube al repo.

# API-Football (api-football.com). Si la pones aca, podes sacarla del cron.
API_FOOTBALL_KEY=tu_api_football_key

# Telegram. TOKEN: hablale a @BotFather -> /newbot.
# CHAT_ID: escribile algo a tu bot y abri https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_TOKEN=tu_telegram_bot_token
TELEGRAM_CHAT_ID=tu_chat_id

# FUENTE DE VERDAD del log de validacion. Poner =1 SOLO en el server: lo declara escritor
# canonico de data/processed/predicciones_log.csv. En local NO la pongas (o =0): asi tus
# corridas de dev escriben a predicciones_log_dev.csv y nunca contaminan el log de produccion.
D_SOCCER_CANONICAL=0
